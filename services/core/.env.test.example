PORT=3000

# Base de datos PostgreSQL
# Docker local → postgresql://krono_user:krono_password@localhost:5432/krono_db
# Dentro de docker-compose → postgresql://krono_user:krono_password@postgres:5432/krono_db
DATABASE_URL=postgresql://krono_user:krono_password@localhost:5432/krono_db

# Redis
# Docker local → redis://localhost:6379
# Dentro de docker-compose → redis://redis:6379
REDIS_URL=redis://localhost:6379

# API Key interna para comunicación entre microservicios
API_KEY=super-secret-api-key

# Tests de integración — apunta a la misma BD o a una separada
# DATABASE_URL_TEST=postgresql://krono_user:krono_password@localhost:5432/krono_test