PORT=3002

# Producción: redis://redis:6379
# Tests:      redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Debe coincidir con flash-fill
JWT_SECRET=cambia_este_valor_en_produccion
JWT_EXPIRY_SECONDS=120

# URL del frontend para el link de confirmación
FLASH_FILL_BASE_URL=http://localhost:5174/confirmar?token=

# Producción: ghost-messenger-notifications
# Tests:      ghost-messenger-notifications-test
BULLMQ_QUEUE_NAME=ghost-messenger-notifications

# WhatsApp — poner WHATSAPP_MOCK=false en producción
WHATSAPP_MOCK=true
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/PHONE_ID/messages
WHATSAPP_TOKEN=

# Gmail (nodemailer) — usa una App Password de Google, no la contraseña normal
# Cómo generar App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=barberiakrono@gmail.com
